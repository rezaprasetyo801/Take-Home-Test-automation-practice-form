\f0\fs24 \cf0 \{\
  "info": \{\
    "name": "Petstore API Collection",\
    "_postman_id": "petstore-123",\
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"\
  \},\
  "item": [\
    \{\
      "name": "Create Pet",\
      "request": \{\
        "method": "POST",\
        "header": [\
          \{ "key": "Content-Type", "value": "application/json" \}\
        ],\
        "url": \{\
          "raw": "https://petstore.swagger.io/v2/pet"\
        \},\
        "body": \{\
          "mode": "raw",\
          "raw": "\{\\n  \\"id\\": 0,\\n  \\"name\\": \\"doggie\\",\\n  \\"status\\": \\"available\\"\\n\}"\
        \}\
      \},\
      "event": [\
        \{\
          "listen": "test",\
          "script": \{\
            "exec": [\
              "pm.test('Status code is 200', function () \{",\
              "    pm.response.to.have.status(200);",\
              "\});",\
              "",\
              "let jsonData = pm.response.json();",\
              "pm.environment.set('petId', jsonData.id);"\
            ]\
          \}\
        \}\
      ]\
    \},\
    \{\
      "name": "Get Pet (Chaining)",\
      "request": \{\
        "method": "GET",\
        "url": \{\
          "raw": "https://petstore.swagger.io/v2/pet/\{\{petId\}\}"\
        \}\
      \},\
      "event": [\
        \{\
          "listen": "test",\
          "script": \{\
            "exec": [\
              "pm.test('Status code is 200', function () \{",\
              "    pm.response.to.have.status(200);",\
              "\});",\
              "",\
              "let jsonData = pm.response.json();",\
              "pm.test('Validate petId', function () \{",\
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get('petId')));",\
              "\});"\
            ]\
          \}\
        \}\
      ]\
    \},\
    \{\
      "name": "Update Pet",\
      "request": \{\
        "method": "PUT",\
        "header": [\
          \{ "key": "Content-Type", "value": "application/json" \}\
        ],\
        "url": \{\
          "raw": "https://petstore.swagger.io/v2/pet"\
        \},\
        "body": \{\
          "mode": "raw",\
          "raw": "\{\\n  \\"id\\": \{\{petId\}\},\\n  \\"name\\": \\"doggie-updated\\",\\n  \\"status\\": \\"sold\\"\\n\}"\
        \}\
      \},\
      "event": [\
        \{\
          "listen": "test",\
          "script": \{\
            "exec": [\
              "pm.test('Update success', function () \{",\
              "    pm.response.to.have.status(200);",\
              "\});"\
            ]\
          \}\
        \}\
      ]\
    \},\
    \{\
      "name": "Delete Pet",\
      "request": \{\
        "method": "DELETE",\
        "url": \{\
          "raw": "https://petstore.swagger.io/v2/pet/\{\{petId\}\}"\
        \}\
      \},\
      "event": [\
        \{\
          "listen": "test",\
          "script": \{\
            "exec": [\
              "pm.test('Delete success', function () \{",\
              "    pm.response.to.have.status(200);",\
              "\});"\
            ]\
          \}\
        \}\
      ]\
    \},\
    \{\
      "name": "Negative - Get Invalid ID",\
      "request": \{\
        "method": "GET",\
        "url": \{\
          "raw": "https://petstore.swagger.io/v2/pet/99999999"\
        \}\
      \},\
      "event": [\
        \{\
          "listen": "test",\
          "script": \{\
            "exec": [\
              "pm.test('Status code is 404', function () \{",\
              "    pm.response.to.have.status(404);",\
              "\});"\
            ]\
          \}\
        \}\
      ]\
    \}\
  ]\
\}}